{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/libre-ai/ai-practices/schemas/activity.v1.schema.json",
  "title": "Libre AI Practices Activity v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "status",
    "locale",
    "title",
    "type",
    "objective",
    "prerequisites",
    "situation",
    "instructions",
    "permitted_data",
    "success_criteria",
    "feedback",
    "risks",
    "limits",
    "stop_conditions",
    "source_refs",
    "claims",
    "media",
    "ai_assistance",
    "review",
    "retire_when"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^activity-[a-z0-9-]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "review", "approved", "blocked", "retired"] },
    "locale": { "type": "string", "minLength": 2 },
    "title": { "type": "string", "minLength": 3 },
    "type": { "enum": ["scenario", "experiment", "simulation"] },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observable_outcome", "competency_ids"],
      "properties": {
        "observable_outcome": { "type": "string", "minLength": 20 },
        "competency_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^comp-[a-z0-9-]+$" }
        }
      }
    },
    "prerequisites": { "type": "array", "items": { "type": "string", "minLength": 3 } },
    "situation": { "type": "string", "minLength": 20 },
    "instructions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "permitted_data": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["data_id", "label", "license", "classification"],
        "properties": {
          "data_id": { "type": "string", "pattern": "^data-[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 3 },
          "license": { "type": "string", "minLength": 3 },
          "classification": { "enum": ["public", "synthetic", "internal_redacted"] }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "locked_dependencies", "network"],
      "properties": {
        "runtime": { "type": "string", "minLength": 2 },
        "locked_dependencies": { "type": "array", "items": { "type": "string", "minLength": 2 } },
        "network": { "enum": ["forbidden", "loopback_only", "explicit_allowlist"] }
      }
    },
    "success_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principle", "remediation"],
      "properties": {
        "principle": { "type": "string", "minLength": 20 },
        "remediation": { "type": "string", "minLength": 20 }
      }
    },
    "risks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "limits": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^source-[a-z0-9-]+$" }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "statement", "source_ids"],
        "properties": {
          "claim_id": { "type": "string", "pattern": "^claim-[a-z0-9-]+$" },
          "statement": { "type": "string", "minLength": 20 },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^source-[a-z0-9-]+$" }
          }
        }
      }
    },
    "media": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["media_id", "provenance", "license", "alt_text", "reviewed_by"],
        "properties": {
          "media_id": { "type": "string", "pattern": "^media-[a-z0-9-]+$" },
          "provenance": { "type": "string", "minLength": 3 },
          "license": { "type": "string", "minLength": 3 },
          "alt_text": { "type": "string", "minLength": 3 },
          "reviewed_by": { "type": "array", "items": { "type": "string", "minLength": 2 } }
        }
      }
    },
    "ai_assistance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["used", "details"],
      "properties": {
        "used": { "type": "boolean" },
        "details": { "type": ["string", "null"] }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "reviewers", "last_reviewed_at", "confidence"],
      "properties": {
        "author": { "type": "string", "minLength": 2 },
        "reviewers": { "type": "array", "items": { "type": "string", "minLength": 2 } },
        "last_reviewed_at": { "type": ["string", "null"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" }
      }
    },
    "retire_when": { "type": "string", "minLength": 10 }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "experiment" } }, "required": ["type"] },
      "then": { "required": ["environment"] }
    }
  ]
}
