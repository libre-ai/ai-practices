{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rumble-ai-practices.local/schemas/audit-existing.schema.json",
  "title": "Existing App Audit Item",
  "type": "object",
  "required": ["id", "source", "category", "severity", "problem", "recommendation", "reviewer", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^audit-[0-9]+$" },
    "source": { "enum": ["capture", "export", "video", "question", "other"] },
    "original_text": { "type": "string" },
    "screenshot": { "type": "string" },
    "category": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "factual_error",
          "misleading_feedback",
          "oversimplification",
          "prompt_dogma",
          "privacy_risk",
          "security_risk",
          "media_bias",
          "missing_source",
          "ambiguous_question"
        ]
      }
    },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "problem": { "type": "string", "minLength": 20 },
    "recommendation": { "enum": ["remove", "rewrite", "contextualize", "source", "block"] },
    "replacement_idea": { "type": "string" },
    "reviewer": { "type": "string" },
    "status": { "enum": ["open", "accepted", "fixed", "rejected"] }
  },
  "additionalProperties": false
}
